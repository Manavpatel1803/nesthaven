# Database (TiDB Cloud)
DB_HOST=your-db-host.tidbcloud.com
DB_PORT=4000
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL_CA=ca1.pem

# Uniplaces API
UNIPLACES_API_KEY=your-uniplaces-api-key

# Adzuna Jobs API
VUE_APP_ADZUNA_APP_ID=your-adzuna-app-id
VUE_APP_ADZUNA_API_KEY=your-adzuna-api-key

# Google OAuth
VUE_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Web3Forms (contact form)
VUE_APP_WEB3FORMS_API_KEY=your-web3forms-api-key

# Other
BaseURL=https://api-export.staging-uniplaces.com/v1
CronJob=0 */8 * * *
