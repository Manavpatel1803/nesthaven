<template>
  <div id="app">
    <header class="u-clearfix u-header u-white u-header" id="sec-be4a">
      <div class="u-clearfix u-sheet u-valign-middle-md u-valign-middle-sm u-valign-middle-xs u-sheet-1">
        <a href="" class="u-image u-logo u-image-1" data-image-width="4000" data-image-height="1182">
          <img src="../assets/images/logo-transparent-png1.png" class="u-logo-image u-logo-image-1">
        </a>
        
        <!-- Navigation -->
        <nav class="u-custom-menu u-nav-container">
          <div class="u-nav-container">
            <div class="u-nav-header">
              <button class="u-hamburger" @click="toggleMenu">
                <span class="u-bar"></span>
                <span class="u-bar"></span>
                <span class="u-bar"></span>
              </button>
            </div>
            <ul :class="['u-nav u-unstyled u-nav-1', { 'u-show': isMenuOpen }]">
              <li class="u-nav-item" v-for="item in navItems" :key="item.text">
                <router-link class="u-button-style u-nav-link u-text-black" :to="item.link" style="padding: 10px 20px;">
                  {{ item.text }}
                </router-link>
              </li>
            </ul>
          </div>
          
          <!-- Collapse Menu for Mobile -->
          <div class="u-custom-menu u-nav-container-collapse" :class="{ 'u-show': isMenuOpen }">
            <div class="u-black u-container-style u-inner-container-layout u-opacity u-opacity-95 u-sidenav">
              <div class="u-inner-container-layout u-sidenav-overflow">
                <div class="u-menu-close" @click="toggleMenu"></div>
                <ul class="u-align-center u-nav u-popupmenu-items u-unstyled u-nav-2">
                  <li class="u-nav-item" v-for="item in navItems" :key="item.text">
                    <a class="u-button-style u-nav-link" :href="item.link">{{ item.text }}</a>
                  </li>
                </ul>
              </div>
            </div>
            <div class="u-black u-menu-overlay u-opacity u-opacity-70" @click="toggleMenu"></div>
          </div>
        </nav>

        <!-- User Profile with Google One Tap -->
        <div v-if="user" class="user-profile">
          <img :src="user.picture" alt="Profile Picture" @click="toggleMenu" />
          <div v-if="showMenu" class="menu">
            <button @click="logout">Logout</button>
          </div>
        </div>
      </div>
    </header>

    <main>
      <p v-if="!user">Please login using Google One Tap.</p>
      <p v-else>Welcome, {{ user.name }}!</p>
    </main>
  </div>
</template>

<script>
export default {
  name: 'AppNavbar',
  data() {
    return {
      user: null, // User profile data
      showMenu: false, // Show/hide logout menu
      isMenuOpen: false, // Hamburger menu state
      navItems: [
        { text: 'Home', link: '/' },
        { text: 'Essential Guide', link: '/essential-guide' },
        { text: 'Jobs', link: '/jobs' },
        { text: 'Accommodation', link: '/accommodation' },
        { text: 'About Us', link: '/about' },
        { text: 'Contact Us', link: '/contact' },
      ],
    };
  },
  methods: {
    toggleMenu() {
      this.isMenuOpen = !this.isMenuOpen;
      this.showMenu = !this.showMenu; // Toggle the profile menu as well
    },
    logout() {
      this.user = null; // Clear user data
      localStorage.removeItem("user"); // Remove from localStorage
      window.location.reload(); // Reload to reset Google One Tap
    },
    handleCredentialResponse(response) {
      console.log("Credential Response:", response);

      if (!response || !response.credential) {
        console.error("No credentials received or response is invalid!");
        return;
      }

      const jwtToken = response.credential;

      // Log the token to ensure it's correct
      console.log("Received JWT Token:", jwtToken);

      // Decode and verify the token
      fetch(`https://oauth2.googleapis.com/tokeninfo?id_token=${jwtToken}`)
        .then(res => res.json())
        .then(data => {
          if (data.error) {
            console.error("Token validation failed:", data.error);
          } else {
            console.log("Token validation success:", data);

            // Save user data from the token
            this.user = {
              name: data.name,
              picture: data.picture,
              email: data.email,
            };
            localStorage.setItem("user", JSON.stringify(this.user)); // Save to localStorage
          }
        })
        .catch(error => {
          console.error("Error validating token:", error);
        });
    },
  },
  mounted() {
    // Load Google API script dynamically
    const script = document.createElement("script");
    script.src = "https://accounts.google.com/gsi/client";
    script.async = true;
    script.defer = true;
    script.onload = () => {
      // Check if user is already logged in
      if (localStorage.getItem("user")) {
        this.user = JSON.parse(localStorage.getItem("user"));
      } else {
        // Initialize Google One Tap only after script is loaded
        window.google.accounts.id.initialize({
          client_id: "560447238232-kfsg2t8ftmk6k36rso4gd8afbi77b1jn.apps.googleusercontent.com", // Replace with your actual Google Client ID
          callback: this.handleCredentialResponse,
        });
        
        // Manually trigger the One Tap prompt
        window.google.accounts.id.prompt();
      }
    };

    // Append the script tag to load the Google One Tap API
    document.head.appendChild(script);
  },
};
</script>

